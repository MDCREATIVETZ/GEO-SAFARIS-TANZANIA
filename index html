                        <textarea id="userMessage" name="userMessage" rows="4" placeholder="Mention any specific pacing demands, accessibility conditions, or luxury property preferences..."></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary btn-block">
                        <i class="fa-brands fa-whatsapp"></i> Dispatch Request via WhatsApp
                    </button>
                </form>
